<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_campus_student" model="ir.sequence">
            <field name="name">Student Registration</field>
            <field name="code">campus.student</field>
            <field name="prefix">STU/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_campus_fee_challan" model="ir.sequence">
            <field name="name">Fee Challan</field>
            <field name="code">campus.fee.challan</field>
            <field name="prefix">CHL/%(year)s/</field>
            <field name="padding">6</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
