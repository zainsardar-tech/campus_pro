<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_student_id_card" model="ir.actions.report">
        <field name="name">Student ID Card</field>
        <field name="model">campus.student</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">campus_pro.report_student_id_card_template</field>
        <field name="report_file">campus_pro.report_student_id_card_template</field>
        <field name="print_report_name">'ID Card - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_campus_student"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_student_id_card_template">
        <t t-call="web.basic_layout">
            <t t-foreach="docs" t-as="o">
                <div class="page">
                    <!-- ID Card Container - CR80 Size (85.6mm x 54mm) -->
                    <!-- We use slightly larger height in CSS to accommodate print margins or exact fit -->
                    <div t-attf-style="width: 85.6mm; height: 53.98mm; border: 1px solid #d1d5db; border-radius: 4px; overflow: hidden; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; position: relative; margin: 20px auto; background: white; page-break-inside: avoid;">
                        
                        <!-- Header Background -->
                        <div t-attf-style="background: linear-gradient(135deg, {{ o.env.company.campus_id_card_primary_color or '#1e3a8a' }} 0%, {{ o.env.company.campus_id_card_secondary_color or '#3b82f6' }} 100%); height: 18mm; position: absolute; top: 0; width: 100%;"></div>
                        
                        <!-- Content Wrapper -->
                        <div style="position: relative; z-index: 10; padding: 3mm; text-align: center;">
                            
                            <!-- Header Text -->
                            <div style="display: flex; justify-content: space-between; align-items: center; color: white;">
                                <div style="flex: 1; text-align: center;">
                                    <h3 style="margin: 0; font-weight: 700; font-size: 10pt; text-transform: uppercase;">
                                        <t t-esc="o.env.company.campus_id_card_header_text or 'Campus Pro Institute'"/>
                                    </h3>
                                    <p style="margin: 0; font-size: 5pt; opacity: 0.9;">
                                        <t t-esc="o.env.company.campus_id_card_sub_header_text or 'Excellence in Education'"/>
                                    </p>
                                </div>
                            </div>
                            
                            <!-- Main Layout: Photo Left, Content Right -->
                            <div style="display: flex; margin-top: 5mm; align-items: flex-start;">
                                <!-- Photo -->
                                <div style="width: 22mm; margin-right: 2mm;">
                                    <div style="width: 20mm; height: 20mm; border-radius: 50%; border: 2px solid white; overflow: hidden; background: #f3f4f6; box-shadow: 0 1px 2px rgba(0,0,0,0.2); margin: 0 auto;">
                                        <img t-if="o.image" t-att-src="image_data_uri(o.image)" style="width: 100%; height: 100%; object-fit: cover;"/>
                                        <div t-else="" style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: #9ca3af; font-size: 14pt;">
                                            <span>👤</span>
                                        </div>
                                    </div>
                                    <!-- QR Code (if enabled) in sidebar -->
                                    <div t-if="o.env.company.campus_id_card_show_qr and o.qr_code" style="margin-top: 2mm; text-align: center;">
                                         <img t-att-src="image_data_uri(o.qr_code)" style="width: 18mm; height: 18mm;"/>
                                    </div>
                                </div>

                                <!-- Details -->
                                <div style="flex: 1; text-align: left;">
                                    <h2 t-attf-style="color: {{ o.env.company.campus_id_card_primary_color or '#1f2937' }}; margin: 2mm 0 1mm; font-size: 10pt; font-weight: bold; line-height: 1;">
                                        <t t-esc="o.name"/>
                                    </h2>
                                    <p style="color: #6b7280; margin: 0; font-size: 6pt; font-weight: 500;">
                                        Class: <t t-esc="o.class_id.name"/> <t t-if="o.section_id">- <t t-esc="o.section_id.name"/></t>
                                    </p>

                                    <div style="margin-top: 2mm; font-size: 6pt; line-height: 1.3;">
                                        <div style="display: flex;">
                                            <span style="color: #6b7280; width: 18mm; font-weight: 600;">Reg No:</span>
                                            <span style="color: #111827; font-weight: bold;"><t t-esc="o.registration_no"/></span>
                                        </div>
                                        
                                        <div t-if="o.env.company.campus_id_card_show_bform" style="display: flex;">
                                            <span style="color: #6b7280; width: 18mm; font-weight: 600;">CNIC:</span>
                                            <span style="color: #111827;"><t t-esc="o.b_form or '-'"/></span>
                                        </div>
                                        
                                        <div style="display: flex;">
                                            <span style="color: #6b7280; width: 18mm; font-weight: 600;">Guardian:</span>
                                            <span style="color: #111827;"><t t-esc="o.guardian_id.name"/></span>
                                        </div>
                                        
                                        <div t-if="o.env.company.campus_id_card_show_emergency" style="display: flex;">
                                            <span style="color: #6b7280; width: 18mm; font-weight: 600;">Emergency:</span>
                                            <span style="color: #dc2626; font-weight: bold;"><t t-esc="o.guardian_id.phone"/></span>
                                        </div>

                                        <div t-if="o.env.company.campus_id_card_show_address" style="display: flex; margin-top: 1mm;">
                                            <span style="color: #6b7280; width: 18mm; font-weight: 600;">Address:</span>
                                            <span style="color: #374151; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 40mm;"><t t-esc="o.address or '-'"/></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Bottom Bar -->
                            <div t-attf-style="background: {{ o.env.company.campus_id_card_primary_color or '#1e3a8a' }}; height: 3mm; width: 100%; position: absolute; bottom: 0; left: 0;"></div>
                        </div>
                    </div>
                </div>
            </t>
        </t>
    </template>
</odoo>
