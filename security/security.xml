<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model="ir.module.category" id="module_category_campus">
        <field name="name">Campus Pro / Academy</field>
        <field name="description">Helps you manage your institute.</field>
        <field name="sequence">10</field>
    </record>

    <record id="group_campus_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_campus"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_campus_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_category_campus"/>
        <field name="implied_ids" eval="[(4, ref('group_campus_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <!-- WhatsApp Governance -->
    <record id="group_campus_whatsapp_user" model="res.groups">
        <field name="name">WhatsApp Sender</field>
        <field name="category_id" ref="module_category_campus"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_campus_whatsapp_manager" model="res.groups">
        <field name="name">WhatsApp Administrator</field>
        <field name="category_id" ref="module_category_campus"/>
        <field name="implied_ids" eval="[(4, ref('group_campus_whatsapp_user'))]"/>
    </record>
</odoo>
