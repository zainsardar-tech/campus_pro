<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_campus_attendance_tree" model="ir.ui.view">
        <field name="name">campus.attendance.tree</field>
        <field name="model">campus.attendance</field>
        <field name="arch" type="xml">
            <list string="Attendance" decoration-success="state == 'present'" decoration-danger="state == 'absent'" decoration-warning="state == 'late'">
                <field name="date"/>
                <field name="student_id"/>
                <field name="state"/>
                <field name="check_in"/>
                <field name="is_locked" widget="boolean_favorite" nolabel="1"/>
            </list>
        </field>
    </record>

    <record id="view_campus_attendance_form" model="ir.ui.view">
        <field name="name">campus.attendance.form</field>
        <field name="model">campus.attendance</field>
        <field name="arch" type="xml">
            <form string="Attendance">
                <header>
                    <button name="action_lock" string="Lock &amp; Notify" type="object" class="oe_highlight" invisible="is_locked"/>
                    <button name="action_unlock" string="Unlock" type="object" invisible="not is_locked" groups="campus_pro.group_campus_manager"/>
                    <field name="is_locked" widget="statusbar" statusbar_visible="False,True" invisible="1"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="student_id" options="{'no_create': True, 'no_open': True}"/>
                            <field name="state"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="check_in"/>
                        </group>
                    </group>
                    <group>
                        <field name="remarks" readonly="is_locked"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_campus_attendance_search" model="ir.ui.view">
        <field name="name">campus.attendance.search</field>
        <field name="model">campus.attendance</field>
        <field name="arch" type="xml">
            <search string="Search Attendance">
                <field name="student_id"/>
                <field name="date"/>
                <group expand="0" string="Group By">
                    <filter string="Date" name="group_by_date" context="{'group_by': 'date'}"/>
                    <filter string="Student" name="group_by_student" context="{'group_by': 'student_id'}"/>
                    <filter string="Status" name="group_by_status" context="{'group_by': 'state'}"/>
                    <separator/>
                    <filter string="Locked" name="locked" domain="[('is_locked', '=', True)]"/>
                    <filter string="Unlocked" name="unlocked" domain="[('is_locked', '=', False)]"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_campus_attendance" model="ir.actions.act_window">
        <field name="name">Attendance</field>
        <field name="res_model">campus.attendance</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_group_by_date': 1}</field>
    </record>
</odoo>
