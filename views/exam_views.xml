<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_campus_exam_tree" model="ir.ui.view">
        <field name="name">campus.exam.tree</field>
        <field name="model">campus.exam</field>
        <field name="arch" type="xml">
            <list string="Exams">
                <field name="name"/>
                <field name="session_id"/>
                <field name="exam_type"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_campus_exam_form" model="ir.ui.view">
        <field name="name">campus.exam.form</field>
        <field name="model">campus.exam</field>
        <field name="arch" type="xml">
            <form string="Exam">
                <header>
                    <button name="action_schedule" string="Schedule" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_publish" string="Publish Results" type="object" class="oe_highlight" invisible="state != 'completed'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,scheduled,ongoing,completed,published"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="session_id"/>
                        </group>
                        <group>
                            <field name="exam_type"/>
                            <field name="date_start"/>
                            <field name="date_end"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Result Views -->
    <record id="view_campus_exam_result_tree" model="ir.ui.view">
        <field name="name">campus.exam.result.tree</field>
        <field name="model">campus.exam.result</field>
        <field name="arch" type="xml">
            <list string="Exam Results" editable="bottom">
                <field name="exam_id"/>
                <field name="student_id"/>
                <field name="subject_id"/>
                <field name="max_marks"/>
                <field name="obtained_marks"/>
                <field name="percentage"/>
                <field name="grade"/>
            </list>
        </field>
    </record>

    <record id="action_campus_exam" model="ir.actions.act_window">
        <field name="name">Exams</field>
        <field name="res_model">campus.exam</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_campus_exam_result" model="ir.actions.act_window">
        <field name="name">Results</field>
        <field name="res_model">campus.exam.result</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
