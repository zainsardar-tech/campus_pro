<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Guardian Views -->
    <record id="view_campus_guardian_tree" model="ir.ui.view">
        <field name="name">campus.guardian.tree</field>
        <field name="model">campus.guardian</field>
        <field name="arch" type="xml">
            <list string="Guardians">
                <field name="name"/>
                <field name="phone"/>
                <field name="cnic"/>
                <field name="occupation"/>
            </list>
        </field>
    </record>

    <record id="view_campus_guardian_form" model="ir.ui.view">
        <field name="name">campus.guardian.form</field>
        <field name="model">campus.guardian</field>
        <field name="arch" type="xml">
            <form string="Guardian">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Guardian Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="relation"/>
                            <field name="phone"/>
                            <field name="cnic"/>
                        </group>
                        <group>
                            <field name="email"/>
                            <field name="occupation"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Students">
                            <field name="student_ids" readonly="1">
                                <list>
                                    <field name="registration_no"/>
                                    <field name="name"/>
                                    <field name="class_id"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                        <page string="Address">
                            <field name="address"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Student Views -->
    <record id="view_campus_student_tree" model="ir.ui.view">
        <field name="name">campus.student.tree</field>
        <field name="model">campus.student</field>
        <field name="arch" type="xml">
            <list string="Students">
                <field name="registration_no"/>
                <field name="name"/>
                <field name="class_id"/>
                <field name="section_id"/>
                <field name="guardian_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_campus_student_kanban" model="ir.ui.view">
        <field name="name">campus.student.kanban</field>
        <field name="model">campus.student</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" sample="1">
                <field name="id"/>
                <field name="name"/>
                <field name="registration_no"/>
                <field name="class_id"/>
                <field name="image"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click d-flex flex-column">
                            <div class="o_kanban_image">
                                <img t-att-src="kanban_image('campus.student', 'image', record.id.raw_value)" alt="Student" class="o_image_64_max"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div>
                                    <span><field name="registration_no"/></span>
                                </div>
                                <div>
                                    <span>Class: <field name="class_id"/></span>
                                </div>
                                <div class="mt-auto">
                                    <field name="state" widget="label_selection" options="{'classes': {'draft': 'default', 'admission': 'info', 'enrolled': 'success', 'left': 'danger', 'passed': 'warning'}}"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_campus_student_form" model="ir.ui.view">
        <field name="name">campus.student.form</field>
        <field name="model">campus.student</field>
        <field name="arch" type="xml">
            <form string="Student">
                <header>
                    <button name="action_reset_to_draft" string="Reset to Inquiry" type="object" invisible="state not in ['struck_off', 'migration', 'passed', 'left']" groups="campus_pro.group_campus_manager"/>
                    <button name="action_reserve" string="Reserve Seat" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_confirm_admission" string="Confirm Admission" type="object" class="oe_highlight" invisible="state not in ['draft', 'reserved', 'struck_off']"/>
                    <button name="action_enroll" string="Enroll" type="object" class="oe_highlight" invisible="state not in ['admission', 'struck_off']"/>
                    
                    <button name="action_on_hold" string="Put On Hold" type="object" invisible="state not in ['admission', 'enrolled']"/>
                    <button name="action_struck_off" string="Struck Off" type="object" invisible="state not in ['admission', 'enrolled', 'on_hold', 'draft']" confirm="Are you sure you want to STRIKE OFF this student?"/>
                    <button name="action_migrate" string="Migrate Out" type="object" invisible="state not in ['admission', 'enrolled', 'on_hold']"/>
                    <button name="action_passed" string="Mark Passed" type="object" invisible="state != 'enrolled'"/>
                    <button name="action_freeze" string="Freeze Seat" type="object" invisible="state not in ['admission', 'enrolled']" confirm="Are you sure you want to FREEZE this student's fees?"/>
                    <button name="action_alumni" string="Mark as Alumni" type="object" invisible="state != 'passed'"/>

                    <field name="state" widget="statusbar" statusbar_visible="draft,reserved,admission,enrolled,passed"/>
                </header>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar" options="{'preview_image': 'image'}"/>
                    <div class="oe_title">
                        <h1>
                            <field name="registration_no"/>
                        </h1>
                        <h2>
                            <field name="name" placeholder="Student Full Name"/>
                        </h2>
                    </div>
                    <group>
                        <group string="Basic Information">
                            <field name="gr_no"/>
                            <field name="dob"/>
                            <field name="gender"/>
                            <field name="b_form"/>
                            <field name="blood_group"/>
                        </group>
                        <group string="Academic Information">
                            <field name="campus_id"/>
                            <field name="class_id"/>
                            <field name="section_id"/>
                            <field name="session_id"/>
                        </group>
                    </group>
                    <group>
                        <group string="Guardian Information">
                            <field name="guardian_id"/>
                            <field name="guardian_phone"/>
                        </group>
                        <group string="Internal Identification">
                            <field name="qr_code" widget="image" readonly="1" options="{'size': [100, 100]}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Enrollment History">
                            <field name="enrollment_ids">
                                <list>
                                    <field name="session_id"/>
                                    <field name="class_id"/>
                                    <field name="section_id"/>
                                    <field name="roll_no"/>
                                </list>
                            </field>
                        </page>
                        <page string="Academic Intelligence" invisible="state not in ['admission', 'enrolled', 'passed', 'alumni']">
                            <group>
                                <group string="Performance Metrics">
                                    <field name="attendance_percentage" widget="progressbar"/>
                                    <field name="exam_eligibility" widget="boolean_toggle"/>
                                </group>
                                <group string="Risk Analytics">
                                    <field name="dropout_risk" widget="priority" readonly="1"/>
                                </group>
                            </group>
                            <div class="alert alert-info" role="alert" invisible="not exam_eligibility">
                                <i class="fa fa-info-circle me-1"></i> Student meets the 75% attendance threshold for examination eligibility.
                            </div>
                            <div class="alert alert-warning" role="alert" invisible="exam_eligibility">
                                <i class="fa fa-warning me-1"></i> <strong>Critical:</strong> Student is below 75% attendance and might be ineligible for upcoming exams.
                            </div>
                        </page>
                        <page string="Status History">
                            <field name="status_log_ids" readonly="1">
                                <list>
                                    <field name="create_date" string="Date"/>
                                    <field name="previous_state"/>
                                    <field name="new_state"/>
                                    <field name="user_id"/>
                                    <field name="reason"/>
                                </list>
                            </field>
                        </page>
                        <page string="Address">
                            <field name="address"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_campus_guardian" model="ir.actions.act_window">
        <field name="name">Guardians</field>
        <field name="res_model">campus.guardian</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_campus_student" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">campus.student</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register a new student!
            </p>
        </field>
    </record>
    <record id="view_campus_student_search" model="ir.ui.view">
        <field name="name">campus.student.search</field>
        <field name="model">campus.student</field>
        <field name="arch" type="xml">
            <search string="Search Student">
                <field name="name" string="Student Name"/>
                <field name="registration_no"/>
                <field name="gr_no"/>
                <filter string="Active Students" name="active_students" domain="[('state', 'in', ['admission', 'enrolled'])]"/>
                <filter string="Enrolled" name="enrolled" domain="[('state', '=', 'enrolled')]"/>
                <filter string="Inquiries" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Reserved" name="reserved" domain="[('state', '=', 'reserved')]"/>
                <separator/>
                <filter string="Struck Off" name="struck_off" domain="[('state', '=', 'struck_off')]"/>
                <filter string="Migration" name="migration" domain="[('state', '=', 'migration')]"/>
                <filter string="Alumni" name="alumni" domain="[('state', '=', 'alumni')]"/>
                <group expand="0" string="Group By">
                    <filter string="Campus" name="group_by_campus" context="{'group_by': 'campus_id'}"/>
                    <filter string="Class" name="group_by_class" context="{'group_by': 'class_id'}"/>
                    <filter string="Status" name="group_by_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
