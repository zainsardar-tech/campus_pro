<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_campus_whatsapp_log_tree" model="ir.ui.view">
        <field name="name">campus.whatsapp.log.tree</field>
        <field name="model">campus.whatsapp.log</field>
        <field name="arch" type="xml">
            <list string="WhatsApp Audit Logs" create="false" edit="false">
                <field name="timestamp"/>
                <field name="event_type"/>
                <field name="student_id"/>
                <field name="guardian_id"/>
                <field name="mode"/>
                <field name="status" widget="badge" decoration-success="status == 'sent'" decoration-danger="status == 'failed'" decoration-warning="status == 'blocked'"/>
                <field name="user_id"/>
            </list>
        </field>
    </record>

    <record id="view_campus_whatsapp_log_form" model="ir.ui.view">
        <field name="name">campus.whatsapp.log.form</field>
        <field name="model">campus.whatsapp.log</field>
        <field name="arch" type="xml">
            <form string="WhatsApp Log" create="false" edit="false">
                <sheet>
                    <group>
                        <group>
                            <field name="timestamp"/>
                            <field name="event_type"/>
                            <field name="mode"/>
                        </group>
                        <group>
                            <field name="status"/>
                            <field name="user_id"/>
                        </group>
                    </group>
                    <group>
                        <group string="Recipient">
                            <field name="student_id"/>
                            <field name="guardian_id"/>
                        </group>
                        <group string="Template">
                            <field name="template_id"/>
                        </group>
                    </group>
                    <group string="Rendered Message">
                        <field name="rendered_body" readonly="1"/>
                    </group>
                    <group string="Error Handling" invisible="not failure_reason">
                        <field name="failure_reason" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_campus_whatsapp_log" model="ir.actions.act_window">
        <field name="name">WhatsApp Logs</field>
        <field name="res_model">campus.whatsapp.log</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No WhatsApp logs found.
            </p>
            <p>
                All sent and blocked WhatsApp messages will be logged here for audit.
            </p>
        </field>
    </record>
</odoo>
